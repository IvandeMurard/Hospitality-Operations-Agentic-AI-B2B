## NOTE #######################################################################
# This root .env.example belongs to the original `backend/` service.
# For the current Aetherix v2 FastAPI backend used in staging/production,
# use `fastapi-backend/.env.example` as the source of truth.
###############################################################################

# Anthropic Claude API (primary path)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Qdrant Vector Database
# Get your credentials from: https://cloud.qdrant.io/
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# Supabase (PostgreSQL)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Redis (Session State)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password_here

# ElevenLabs (Voice - Optional)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# PredictHQ (Events - Optional)
PREDICTHQ_API_KEY=your_predicthq_api_key_here

# Weather API (Optional)
WEATHER_API_KEY=your_weather_api_key_here

# OpenWeatherMap (Context Layer)
OPENWEATHER_API_KEY=your_openweathermap_key_here

# Mistral AI
MISTRAL_API_KEY=your_mistral_api_key_here

# Serper (Google Search API)
SERPER_API_KEY=your_serper_key_here

# ── Apaleo PMS ────────────────────────────────────────────────────────────────
# OAuth2 client credentials from https://app.apaleo.com → Developer → Apps
APALEO_CLIENT_ID=your-client-id
APALEO_CLIENT_SECRET=your-client-secret
# 3-letter property code shown in Apaleo (e.g. MUC, BER, PAR)
APALEO_PROPERTY_ID=MUC

