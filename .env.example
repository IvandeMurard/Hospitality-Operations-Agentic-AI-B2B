# ── Claude / MCP agent (primary path) ────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Apaleo PMS ────────────────────────────────────────────────────────────────
# OAuth2 client credentials from https://app.apaleo.com → Developer → Apps
APALEO_CLIENT_ID=your-client-id
APALEO_CLIENT_SECRET=your-client-secret
# 3-letter property code shown in Apaleo (e.g. MUC, BER, PAR)
APALEO_PROPERTY_ID=MUC

# ── Mistral ────────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=
QDRANT_API_KEY=

# ── ElevenLabs ────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=

# ── PredictHQ (local events) ──────────────────────────────────────────────────
PREDICTHQ_API_KEY=

# ── OpenWeatherMap ────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=

# ── Serper (Google Search API) ────────────────────────────────────────────────
SERPER_API_KEY=
