# Copy this file to .env and fill in real values.
# NEVER commit .env — it is in .gitignore.
#
# For local Docker (docker-compose), the DATABASE_URL values below are fine.
# For staging/production, point DATABASE_URL at your real Postgres instance
# (not the internal `db` service) and update CORS_ORIGINS to your staging URL.

DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/aetherix
TEST_DATABASE_URL=postgresql+asyncpg://postgres:password@db_test:5432/aetherix_test
SECRET_KEY=changeme-generate-with-secrets.token_hex-32
MAIL_SERVER=mailhog
CORS_ORIGINS=["http://localhost:3000"]  # For local dev; set to ["https://YOUR_STAGING_DOMAIN"] in staging

# ── LLM Providers ─────────────────────────────────────────────────────────
# Claude is always the primary LLM. Gemini is always the automatic fallback.
# If Claude fails (API error, rate limit, timeout), Gemini takes over
# transparently — no configuration or human action required.

# Anthropic — primary LLM (Claude Sonnet)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini — automatic fallback (Gemini 2.0 Flash)
# Get key at: aistudio.google.com (free tier available)
GEMINI_API_KEY=

# Optional model overrides
LLM_MODEL=claude-sonnet-4-6
LLM_FALLBACK_MODEL=gemini-2.0-flash

# ── Embedding Provider ─────────────────────────────────────────────────────
EMBEDDING_MODEL=mistral-embed

# Backboard.io (Memory)
BACKBOARD_API_KEY=...
BACKBOARD_PROJECT_ID=...

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_NUMBER=whatsapp:+...

# Apaleo (PMS)
APALEO_CLIENT_ID=...
APALEO_CLIENT_SECRET=...

# Obsidian vault (knowledge base — synced via OneDrive)
# Windows native path:  C:/Users/IVAN/OneDrive/Documents/Agentic AI Hospitality
# WSL mount path:       /mnt/c/Users/IVAN/OneDrive/Documents/Agentic AI Hospitality
# Docker bind-mount:    set to the path inside the container (e.g. /vault)
# scripts/intelligence_report.py reads this variable — required on Linux/WSL/CI
OBSIDIAN_VAULT_PATH=/mnt/c/Users/IVAN/OneDrive/Documents/Agentic AI Hospitality

# Linear (issue & task tracking)
# IMPORTANT: LINEAR_TEAM_ID doit être l'UUID de l'équipe HOS (pas TAC).
# Pour obtenir l'UUID correct : python scripts/linear_teams.py
LINEAR_API_KEY=lin_api_...
LINEAR_TEAM_ID=2f6bb5e2-d735-4769-9377-11fe186aa0ad
LINEAR_TEAM_ID=<UUID équipe HOS — obtenir via: python scripts/linear_teams.py>
